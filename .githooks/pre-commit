#!/usr/bin/env bash
# Kartonki pre-commit hook — quality gate (level 5 of 7).
#
# Установка (однократно после клонирования):
#   bash scripts/install-hooks.sh
#
# Что проверяется:
#   Всегда:
#     1. Нет .py в корне репозитория (должны жить в scripts/)
#     2. Нет .claude/worktrees/* (временные рабочие копии агентов)
#     3. Нет embedded git repos (submodule mode 160000)
#     4. < 20 файлов в коммите (warning, обход LARGE_COMMIT_OK=1)
#   Если изменены WordData*.kt:
#     5. Глобальные проверки (scripts/validate/find_real_dupes.py):
#        дубли, word count, setId lang-block, rarity spread new sets, cognate pairs
#     6. Per-setId: для КАЖДОГО РЕАЛЬНО ИЗМЕНЁННОГО setId —
#        bash scripts/validate/validate_all.sh <setId>
#
# Изменённые setIds определяются через scripts/validate/changed_setids.py:
# скрипт читает git diff --cached --unified=0, находит диапазоны изменённых
# строк, сопоставляет их с диапазонами WordEntity-блоков в staged-версии файла
# и возвращает только те setIds, внутри WordEntity которых реально что-то
# изменилось. Правки вне WordEntity (импорты, заголовки, комментарии) не
# запускают валидацию setIds.
#
# Это позволяет делать чанковые коммиты на больших legacy-файлах
# (WordDataEnglish.kt 82 setIds) без требования чинить все setIds разом.
#
# Если хук блокирует по ошибке — не используй --no-verify. Лучше исправить
# нарушение или обсудить правило. См. docs/claude/quality_gates.md.
#
# ── METADATA_ONLY_COMMIT escape hatch ────────────────────────────────────────
#
# Флаг METADATA_ONLY_COMMIT=1 разрешает коммитить массовые правки, которые
# добавляют только whitelisted metadata-поле во все WordEntity и не меняют
# семантику слов. Текущий whitelist: {isFillInBlankSafe}.
#
# Активируется ТОЛЬКО совместно с LARGE_COMMIT_OK=1 (защита от случайного
# использования при обычной ручной правке).
#
# При активном флаге:
#   • Хук вызывает scripts/validate/check_metadata_only_diff.py — тот парсит
#     staged diff и сравнивает каждую (удалённую, добавленную) строку. Если
#     после снятия маркера isFillInBlankSafe строки не совпадают — коммит
#     БЛОКИРУЕТСЯ. Флаг самовалидируемый.
#   • Пропускается блок 2b (per-setId validate_all.sh) — pre-existing legacy
#     техдолг не блокирует коммит, который не меняет содержимое слов.
#   • Сохраняются: 2a (find_real_dupes — структура), 2c (WordDataVersion
#     bump — обязателен для любых правок данных), всё из блока 1.
#
# Примеры использования:
#   # Обычный коммит — никаких флагов.
#   git commit -m "..."
#
#   # Mass-mark всех AMBIGUOUS_BLANK-слов:
#   METADATA_ONLY_COMMIT=1 LARGE_COMMIT_OK=1 git commit -m "..."
#
# Тесты флага — .githooks/tests/test_metadata_only.sh.
set -u

cd "$(git rev-parse --show-toplevel)" || exit 1

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
BLUE="\033[0;34m"
NC="\033[0m"

ERRORS=()
WARNS=()

# ── 1. Cleanliness checks — всегда ───────────────────────────────────────────

STAGED=$(git diff --cached --name-only 2>/dev/null)

# 1a. Python files at repo root
BAD_PY=$(echo "$STAGED" | awk -F/ 'NF==1' | grep -E '\.py$' || true)
if [ -n "$BAD_PY" ]; then
  ERRORS+=(".py файлы в корне репозитория не допускаются (должны лежать в scripts/):
$(echo "$BAD_PY" | sed 's/^/    /')
Перенеси: git mv <file> scripts/<file>
Причина: инцидент f353472 — git add -A захватил 60+ ad-hoc скриптов из корня.")
fi

# 1b. .claude/worktrees/*
BAD_WORKTREE=$(echo "$STAGED" | grep -E '^\.claude/worktrees/' || true)
if [ -n "$BAD_WORKTREE" ]; then
  ERRORS+=(".claude/worktrees/ не должны попадать в коммит (временные рабочие копии):
$(echo "$BAD_WORKTREE" | sed 's/^/    /')
Удали из stage: git rm --cached <path>")
fi

# 1c. Embedded git repos (submodule mode 160000)
BAD_SUBMODULE=$(git ls-files --stage 2>/dev/null | awk '$1 == "160000" { print $4 }')
if [ -n "$BAD_SUBMODULE" ]; then
  ERRORS+=("Обнаружены embedded git repositories (mode 160000) — submodule-trap:
$(echo "$BAD_SUBMODULE" | sed 's/^/    /')
Убери из индекса: git rm --cached <path>
Проверь: git ls-files --stage | grep '^160000'")
fi

# 1d. Large commit — warning, обходится LARGE_COMMIT_OK=1
STAGED_COUNT=$(echo "$STAGED" | grep -c . || true)
if [ "$STAGED_COUNT" -ge 20 ] && [ -z "${LARGE_COMMIT_OK:-}" ]; then
  WARNS+=("Большой коммит: $STAGED_COUNT файлов. Убедись, что ничего лишнего.
Список (первые 30):
$(echo "$STAGED" | head -30 | sed 's/^/    /')
$([ "$STAGED_COUNT" -gt 30 ] && echo "    ... и ещё $((STAGED_COUNT - 30))")

Чтобы продолжить, если это сознательный коммит:
    LARGE_COMMIT_OK=1 git commit -m \"...\"")
fi

# ── 2. WordData validation ───────────────────────────────────────────────────

CHANGED_WORDDATA=$(echo "$STAGED" | grep -E '^app/src/main/java/com/example/kartonki/data/WordData.*\.kt$' || true)

if [ -n "$CHANGED_WORDDATA" ]; then
  FILE_COUNT=$(echo "$CHANGED_WORDDATA" | wc -l)
  echo -e "${BLUE}🔍 Валидация WordData (${FILE_COUNT} файл)...${NC}"

  # ── METADATA_ONLY_COMMIT escape hatch acquisition ─────────────────────────
  # Allows skipping 2b (per-setId full validation) when the commit ONLY adds
  # whitelisted metadata fields. Requires both env vars to prevent accidental
  # use. The diff itself is re-checked below by check_metadata_only_diff.py —
  # the flag is self-validating.
  METADATA_ONLY_ACTIVE=0
  if [ -n "${METADATA_ONLY_COMMIT:-}" ]; then
    if [ -z "${LARGE_COMMIT_OK:-}" ]; then
      ERRORS+=("METADATA_ONLY_COMMIT=1 установлен без LARGE_COMMIT_OK=1.
    Флаг разрешения mass-metadata-коммитов требует оба флага одновременно —
    защита от случайного использования при обычной ручной правке.
    Перезапусти как: METADATA_ONLY_COMMIT=1 LARGE_COMMIT_OK=1 git commit ...
    См. комментарии в .githooks/pre-commit.")
    else
      if python scripts/validate/check_metadata_only_diff.py > /tmp/kartonki-metaonly.log 2>&1; then
        METADATA_ONLY_ACTIVE=1
        echo -e "${YELLOW}⚠️  METADATA_ONLY_COMMIT mode active.${NC}"
        echo -e "    Content quality validators (per-setId) skipped."
        echo -e "    Structural (find_real_dupes) and WordDataVersion bump still enforced."
      else
        ERRORS+=("METADATA_ONLY_COMMIT self-validation FAILED — diff содержит правки вне whitelist:
$(head -30 /tmp/kartonki-metaonly.log | sed 's/^/    /')
Whitelist: {isFillInBlankSafe}. Любое другое поле → коммить без флага.")
      fi
    fi
  fi

  # 2a. Глобальные проверки (find_real_dupes) — всегда, включая METADATA_ONLY
  if ! python scripts/validate/find_real_dupes.py > /tmp/kartonki-global.log 2>&1; then
    ERRORS+=("find_real_dupes.py обнаружил глобальные нарушения:
$(tail -40 /tmp/kartonki-global.log | sed 's/^/    /')
Полный отчёт: python scripts/validate/find_real_dupes.py")
  fi

  # 2b. Per-setId: только реально изменённые setIds (определяются скриптом).
  # Пропускается при METADATA_ONLY_ACTIVE=1 — коммит не меняет содержимое слов,
  # проверять data-quality нет смысла. Уже активирующий self-validation выше
  # гарантирует, что правки ограничены whitelisted полями.
  if [ "$METADATA_ONLY_ACTIVE" = "1" ]; then
    echo -e "    Per-setId валидация пропущена (METADATA_ONLY_COMMIT)"
  else
    ALL_SETIDS=$(for f in $CHANGED_WORDDATA; do
      [ -f "$f" ] && python scripts/validate/changed_setids.py "$f" 2>/dev/null
    done | sort -un)

    if [ -n "$ALL_SETIDS" ]; then
      SETID_COUNT=$(echo "$ALL_SETIDS" | wc -l)
      echo -e "    Валидация ${SETID_COUNT} реально изменённых setIds"
      for sid in $ALL_SETIDS; do
        if ! bash scripts/validate/validate_all.sh "$sid" > /tmp/kartonki-set-${sid}.log 2>&1; then
          ERRORS+=("validate_all.sh упал для setId=$sid:
$(grep -E '❌|BLOCK' /tmp/kartonki-set-${sid}.log | head -10 | sed 's/^/    /')
Детали: bash scripts/validate/validate_all.sh $sid")
        fi
      done
    else
      echo -e "    Изменения вне WordEntity-блоков (или пустой diff), per-setId валидация пропущена"
    fi
  fi

  # 2c. WordDataVersion.CURRENT bump — если меняются данные, версия должна расти
  #
  # Причина: WordLoader при старте приложения перечитывает все слова только если
  # WordDataVersion.CURRENT != сохранённая в prefs. Без bump существующие установки
  # приложения не увидят новые тексты/группировки — накопленный техдолг на ~80
  # коммитов обнаружен 2026-04-21.
  CHANGED_DATA_ONLY=$(echo "$CHANGED_WORDDATA" | grep -vE '/WordDataVersion\.kt$' || true)
  if [ -n "$CHANGED_DATA_ONLY" ]; then
    VERSION_PATH="app/src/main/java/com/example/kartonki/data/WordDataVersion.kt"
    VERSION_STAGED=$(echo "$CHANGED_WORDDATA" | grep -E '/WordDataVersion\.kt$' || true)
    if [ -z "$VERSION_STAGED" ]; then
      ERRORS+=("Изменены WordData*.kt, но WordDataVersion.kt не в staging:
$(echo "$CHANGED_DATA_ONLY" | head -5 | sed 's/^/    /')
Открой $VERSION_PATH и увеличь CURRENT на 1, затем: git add $VERSION_PATH
Причина: WordLoader сверяет CURRENT с сохранённой версией, иначе изменения не видны пользователям.")
    else
      OLD_VER=$(git show HEAD:$VERSION_PATH 2>/dev/null | grep -oE 'CURRENT = [0-9]+' | grep -oE '[0-9]+' || echo "0")
      NEW_VER=$(grep -oE 'CURRENT = [0-9]+' "$VERSION_PATH" | grep -oE '[0-9]+' || echo "0")
      if [ "$NEW_VER" -le "$OLD_VER" ]; then
        ERRORS+=("WordDataVersion.CURRENT не увеличен: было $OLD_VER, стало $NEW_VER.
Открой $VERSION_PATH и поставь CURRENT = $((OLD_VER + 1)) или больше.")
      fi
    fi
  fi
fi

# ── 3. Финальный вердикт ─────────────────────────────────────────────────────

echo ""
if [ ${#ERRORS[@]} -eq 0 ] && [ ${#WARNS[@]} -eq 0 ]; then
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN}✅ PASSED${NC} — все проверки пройдены"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 0
fi

echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ ${#ERRORS[@]} -gt 0 ]; then
  echo -e "${RED}❌ BLOCKED${NC} — ${#ERRORS[@]} нарушений"
  for e in "${ERRORS[@]}"; do
    echo ""
    echo -e "${RED}▸${NC} $e"
  done
fi
if [ ${#WARNS[@]} -gt 0 ]; then
  echo ""
  echo -e "${YELLOW}⚠️  Требует подтверждения:${NC}"
  for w in "${WARNS[@]}"; do
    echo ""
    echo -e "${YELLOW}▸${NC} $w"
  done
fi
echo ""
echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "Подробности: docs/claude/quality_gates.md"
echo ""
exit 1
