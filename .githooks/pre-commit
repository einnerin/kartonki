#!/usr/bin/env bash
# Pre-commit hook: блокирует коммит если данные наборов слов нарушают правила.
#
# Установка (однократно):
#   git config core.hooksPath .githooks
#
# Что проверяется (find_real_dupes.py):
#   1. Украденные слова — Room UNIQUE(original+languagePair): любой дубль в ЛЮБОМ файле
#   2. Все наборы = 25 слов после симуляции Room REPLACE
#   3. Слишком большой разброс редкости в новых наборах (> 2 смежных уровня)
#   4. Нарушение формулы ID: id ≠ setId×100 + позиция
#   5. Дублирующиеся имена наборов в одном языке
#   6. Отсутствие topic/level в новых наборах
#   7. Однокоренные пары внутри нового набора

cd "$(git rev-parse --show-toplevel)" || exit 1

# Запускаем при любом изменении .kt-файлов или самого скрипта валидации
CHANGED=$(git diff --cached --name-only | grep -E '\.(kt|py)$' || true)
if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "🔍 Проверка наборов слов (find_real_dupes.py)..."
echo ""

if python find_real_dupes.py; then
  echo ""
  exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Что делать:"
echo "  Украденные слова:"
echo "    → слово уже есть в другом наборе — Room (unique index) тихо удалит старый entry"
echo "    → замени слово в НАБОРЕ-ЛУЗЕРЕ на то, которого нет ни в одном другом"
echo "    → python find_real_dupes.py  # проверь после исправления"
echo ""
echo "  Набор ≠ 25 слов:"
echo "    → это следствие дубля выше — исправь дубль, счётчик восстановится"
echo ""
echo "  Разброс редкости:"
echo "    → набор должен содержать ≤ 2 смежных уровня (напр. RARE+EPIC)"
echo "    → замени слова выбивающегося уровня на подходящие"
echo ""
echo "  Нарушение формулы ID:"
echo "    → id должен быть setId×100 + порядковый номер (1,2,3...)"
echo ""
echo "  Дублирующиеся имена:"
echo "    → у двух наборов одного языка не может быть одинакового name"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit 1
