<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup and device-transfer rules for Android 12+ (API 31+).

    cloud-backup   : Google Drive automatic backup (used when switching phones)
    device-transfer: Direct phone-to-phone transfer (Android setup wizard)

    What we back up:
      - kartonki.db  : Room database — collection, progress, achievements,
                       decks, favourite sets, streaks, PvP history
      - user_prefs   : SharedPreferences — username, avatar, language pair,
                       quiz settings, problem-words settings
-->
<data-extraction-rules>

    <cloud-backup>
        <include domain="database"   path="kartonki.db"/>
        <include domain="sharedpref" path="user_prefs.xml"/>
    </cloud-backup>

    <device-transfer>
        <include domain="database"   path="kartonki.db"/>
        <include domain="sharedpref" path="user_prefs.xml"/>
    </device-transfer>

</data-extraction-rules>
