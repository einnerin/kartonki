# Built application files
*.apk
*.aar
*.ap_
*.aab

# Local Maven proxy cache — артефакты подтягиваются скриптом maven_proxy.js,
# не должны попадать в репо
localMaven/

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/
!scripts/release/

# Gradle files
.gradle/
build/
**/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
!/.idea/codeStyles/
!/.idea/copyright/
!/.idea/dataSources/
!/.idea/inspectionProfiles/
!/.idea/runConfigurations/
!/.idea/scopes/
!/.idea/vcs.xml

# Keystore files
*.jks
*.keystore
# Signing config with keystore passwords — must NEVER be committed
keystore.properties

# Google Services (contains sensitive keys)
google-services.json

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# OS
.DS_Store
Thumbs.db

# Node.js
node_modules/

# Python bytecode
__pycache__/
*.pyc

# Claude workspace
.claude/worktrees/
.claude/settings.local.json

# Ad-hoc output at repo root (intentional tooling lives in scripts/)
/*.log
/check*.txt
/test_out.txt
/coverage_*.txt
/ANALYSIS_RESULTS.txt
/same_roots.txt

# Scratch files: any file starting with underscore inside scripts/ is ad-hoc
# pilot data / test fixture / debug dump and must never be committed. This is
# defence in depth against an accidental `git add -A` capturing them.
scripts/**/_*

# Session-local harness state
.claude/scheduled_tasks.lock

# General temp files
*.tmp
/tmp-*

# FILL_IN_BLANK pipeline scratch files (prompts for subagents, their JSON outputs)
# Lifecycle: generated → consumed by generate_fill_in_blank_exclusions.py → deleted.
# Kept at repo root during the session because subagents' Read needs paths inside cwd.
/.prompt_*.md
/.out_*.json
